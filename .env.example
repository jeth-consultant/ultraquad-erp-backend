# Server
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
# Comma-separated list of allowed CORS origins, e.g. https://app.ultraquad.org,https://admin.ultraquad.org
CORS_ORIGINS=

# Database
DATABASE_URL=postgres://user:password@localhost:5432/ultraquad

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# M-Pesa Daraja
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_HMAC_SECRET=
MPESA_CALLBACK_BASE_URL=https://api.ultraquad.org
# Optional comma-separated extra IPs allowed to call /api/mpesa/* (e.g. your ngrok tunnel IP during sandbox testing)
MPESA_ALLOWED_IPS=

# Set to true when running behind a reverse proxy/load balancer (needed for the
# M-Pesa IP allowlist to see the real client IP)
TRUST_PROXY=false

# Email (SMTP) - used for password reset OTPs
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=UltraQuad ERP <no-reply@ultraquad.org>

# Firebase Cloud Messaging
FIREBASE_SERVICE_ACCOUNT_JSON=

# GitHub
GITHUB_PAT=

# Sentry
SENTRY_DSN=

# Logging
LOG_LEVEL=info
